          "explore": {
            "permission": {
              "edit": "deny",
              "write": "deny",
              "plan_read": "deny",
              "todoread": "deny",
              "bash": {
                "*": "deny",
                "ls *": "allow",
                "tree *": "allow",
                "pwd": "allow",
                "cat *": "allow",
                "head *": "allow",
                "tail *": "allow",
                "wc *": "allow",
                "file *": "allow",
                "stat *": "allow",
                "grep *": "allow",
                "rg *": "allow",
                "find *": "allow",
                "git status*": "allow",
                "git log*": "allow",
                "git diff*": "allow",
                "git show*": "allow",
                "git blame*": "allow",
                "git branch*": "allow",
                "git ls-files*": "allow",
                "uname*": "allow",
                "hostname": "allow",
                "whoami": "allow",
                "which *": "allow",
                "realpath *": "allow",
              },
            },
          },
        },
        "permission": {
          "webfetch": "deny",
          "worktree_*": "deny",
        },
      },
    },
  },
}
